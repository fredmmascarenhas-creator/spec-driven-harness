#!/bin/bash
# METHODOLOGY Git Hook - Pre-commit Validation
# Ensures traceability and STATE.md updates

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${GREEN}[METHODOLOGY]${NC} Running pre-commit checks..."

# Check 1: Commit message has traceability
COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"

if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
  
  if ! echo "$COMMIT_MSG" | grep -qE "^(TASK|REQ|DESIGN|FIX|IMPL|TEST)-[A-Z]+-[0-9]+:"; then
    echo -e "${RED}❌ FAIL${NC} - Missing traceability in commit message"
    echo ""
    echo "Format: TASK-XXX-001: Brief description"
    echo ""
    echo "Examples:"
    echo "  TASK-SUP-006: Integrate KnowledgeBase with Model Router"
    echo "  REQ-AUTH-001: Add Google OAuth support"
    echo "  FIX-BUG-123: Fix login timeout issue"
    echo ""
    echo "Your message:"
    echo "$COMMIT_MSG"
    exit 1
  fi
  echo -e "${GREEN}✓${NC} Traceability check passed"
fi

# Check 2: If code changed, STATE.md should be updated (warning only)
CODE_FILES=$(git diff --cached --name-only | grep -E '\.(js|ts|py|java|go|rs|cpp|c)$' || true)
STATE_UPDATED=$(git diff --cached --name-only | grep -E 'STATE\.md$' || true)

if [ -n "$CODE_FILES" ] && [ -z "$STATE_UPDATED" ]; then
  echo -e "${YELLOW}⚠️  WARNING${NC} - Code changed but STATE.md not updated"
  echo ""
  echo "Files changed:"
  echo "$CODE_FILES" | sed 's/^/  - /'
  echo ""
  echo "Did you make a decision? Update .specs/project/STATE.md"
  echo ""
  echo "To skip this warning: git commit --no-verify"
  # Don't exit - warning only
fi

# Check 3: No orphan REQ-XXX in code without corresponding spec
STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
  if [ -f "$file" ]; then
    # Extract REQ-XXX references
    REQS=$(grep -oE 'REQ-[A-Z]+-[0-9]+' "$file" 2>/dev/null || true)
    
    for req in $REQS; do
      # Check if spec exists
      SPEC_FILE=$(find .specs -name "*.md" -exec grep -l "$req" {} \; 2>/dev/null || true)
      
      if [ -z "$SPEC_FILE" ]; then
        echo -e "${YELLOW}⚠️  WARNING${NC} - Orphan requirement: $req in $file"
        echo "  No spec found in .specs/ directory"
        echo "  Consider creating .specs/features/$req/spec.md"
      fi
    done
  fi
done

echo -e "${GREEN}✓${NC} All checks passed"
exit 0
